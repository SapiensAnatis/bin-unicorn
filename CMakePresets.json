{
    "version": 10,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "$comment": [
                "We use the multi-config generator to play nice with the Pico VSCode extension",
                "It expects the build directory to always be build/ which doesn't work with separate Debug/Release configure steps",
                "Surprisingly, this doesn't appear to cause any issues with the Pico SDK"
            ],
            "name": "default",
            "generator": "Ninja Multi-Config",
            "displayName": "Default",
            "binaryDir": "${sourceDir}/build"
        }
    ],
    "buildPresets": [
        {
            "name": "base",
            "hidden": true,
            "jobs": 8
        },
        {
            "name": "debug",
            "configuration": "Debug",
            "inherits": "base",
            "displayName": "Debug",
            "configurePreset": "default"
        },
        {
            "name": "release",
            "configuration": "RelWithDebInfo",
            "inherits": "base",
            "displayName": "RelWithDebInfo",
            "configurePreset": "default"
        }
    ]
}